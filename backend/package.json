  },
  "devDependencies": {
    "@types/bcrypt":       "^5.0.2",
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan":       "^1.9.9",
    "@types/node":         "^20.12.7",
