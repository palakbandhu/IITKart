generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  VENDOR
  RIDER
  ADMIN
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  CASH_ON_DELIVERY
  KART_COINS
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  phone           String   @unique
  password        String
  name            String
  role            Role     @default(CUSTOMER)
  createdAt       DateTime @default(now())
  hostel          String?
  roomNumber      String?
  profileImageUrl String?

  // OTP / password reset
  otpHash       String?
  otpExpiry     DateTime?
  otpAttempts   Int       @default(0)

  // Relations
  orders        Order[]        @relation("CustomerOrders")
  vendorProfile VendorProfile?
  riderProfile  RiderProfile?
  cart          Cart?
  wallet        KartWallet?
  reviews       Review[]
  complaints    Complaint[]
  payments      Payment[]
}

model VendorProfile {
  id          Int     @id @default(autoincrement())
  shopName    String
  shopType    String
  openingTime String
  closingTime String
  description String?
  address     String?
  contactNo   String?
  isOpen      Boolean @default(true)
  imageUrl    String?

  // Aggregated rating (updated on each review)
  averageRating Float @default(0)
  totalReviews  Int   @default(0)
  totalEarnings Float @default(0)

  orders   Order[]
  products Product[]
  reviews  Review[]

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  imageUrl    String?
  category    String?
  isAvailable Boolean  @default(true)
  isDeleted   Boolean  @default(false)

  vendorId Int
  vendor   VendorProfile @relation(fields: [vendorId], references: [id])

  orderItems OrderItem[]
  cartItems  CartItem[]
  reviews    Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([vendorId])
  @@index([category])
}

model RiderProfile {
  id             Int     @id @default(autoincrement())
  vehicleType    String
  vehicleNo      String?
  isAvailable    Boolean @default(true)
  totalDeliveries Int    @default(0)
  totalEarnings   Float  @default(0)

  // Aggregated rating
  averageRating Float @default(0)
  totalReviews  Int   @default(0)

  deliveries Order[]
  reviews    Review[]

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id          Int         @id @default(autoincrement())
  customerId  Int
  vendorId    Int
  riderId     Int?
  status      OrderStatus @default(PENDING)
  totalAmount Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Delivery address snapshot (captured at order time)
  deliveryAddress String?

  customer User          @relation("CustomerOrders", fields: [customerId], references: [id])
  vendor   VendorProfile @relation(fields: [vendorId], references: [id])
  rider    RiderProfile? @relation(fields: [riderId], references: [id])

  items     OrderItem[]
  payment   Payment?
  review    Review?
  complaint Complaint?

  @@index([customerId])
  @@index([vendorId])
  @@index([riderId])
}

model OrderItem {
  id        Int   @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int   @default(1)
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  cart      Cart     @relation(fields: [cartId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id              Int           @id @default(autoincrement())
  orderId         Int           @unique
  userId          Int
  amount          Float
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Razorpay fields (null for COD)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // Kart Coins used in this payment
  coinsUsed         Int?

  order  Order @relation(fields: [orderId], references: [id])
  user   User  @relation(fields: [userId], references: [id])
}

// ─── Kart Coins Wallet ────────────────────────────────────────────────────────

model KartWallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  balance   Int      @default(0)   // stored as integer coins
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  walletId    Int
  amount      Int      // positive = credit, negative = debit
  description String
  orderId     Int?
  createdAt   DateTime @default(now())

  wallet KartWallet @relation(fields: [walletId], references: [id])
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())

  // Author
  userId    Int
  user      User @relation(fields: [userId], references: [id])

  // Target (at least one must be set)
  orderId   Int?          @unique
  order     Order?        @relation(fields: [orderId], references: [id])

  vendorId  Int?
  vendor    VendorProfile? @relation(fields: [vendorId], references: [id])

  riderId   Int?
  rider     RiderProfile?  @relation(fields: [riderId], references: [id])

  productId Int?
  product   Product?       @relation(fields: [productId], references: [id])
}

// ─── Complaints ───────────────────────────────────────────────────────────────

model Complaint {
  id          Int             @id @default(autoincrement())
  subject     String
  description String
  status      ComplaintStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  userId  Int
  user    User   @relation(fields: [userId], references: [id])

  orderId Int?   @unique
  order   Order? @relation(fields: [orderId], references: [id])
}
